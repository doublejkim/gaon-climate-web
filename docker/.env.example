# docker compose 빌드/실행 시 주입되는 변수입니다.
# 이 파일을 복사해 docker/.env 로 만든 뒤 값을 채우세요.
#   cp docker/.env.example docker/.env

# Traefik 라우팅용 프론트 도메인 (실도메인은 .env에만, 커밋 금지).
# 변경 시 재빌드 불필요 — docker compose up -d 만 하면 라우팅 갱신됨.
WEB_DOMAIN=your-web.domain

# 백엔드의 "공개" 주소 (브라우저가 직접 호출). docker 내부 호스트명은 사용 불가.
# 백엔드도 Traefik에 별도 Host로 노출되어 있어야 한다.
# 주의: 빌드 시점에 정적 파일로 인라인됨 → 값 변경 시 `up -d --build` 로 재빌드 필요.
VITE_API_BASE_URL=https://your-api.domain
